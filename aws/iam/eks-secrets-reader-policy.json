{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadAppSecrets",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:GetSecretValue",
        "secretsmanager:DescribeSecret"
      ],
      "Resource": [
        "arn:aws:secretsmanager:us-east-1:PLACEHOLDER_AWS_ACCOUNT_ID:secret:angular-micro/user-service/db-*",
        "arn:aws:secretsmanager:us-east-1:PLACEHOLDER_AWS_ACCOUNT_ID:secret:angular-micro/product-service/db-*"
      ]
    }
  ]
}
