# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is in .gitignore — never commit secrets.

aws_region        = "us-east-1"
github_repository = "hitsshaa/AngularDotNetMicroservices"
github_branch     = "main"

# Must be 8-128 chars and include upper, lower, digit, and symbol per SQL Server policy.
rds_admin_username = "sqladmin"
rds_admin_password = "ChangeMe_Strong_Password_1!"

# Optional cost levers
# node_instance_type        = "t3.medium"
# node_desired_size         = 2
# rds_instance_class        = "db.t3.small"
# rds_allocated_storage_gb  = 20
