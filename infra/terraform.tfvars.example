# Copy this file to terraform.tfvars and fill in the values.
# terraform.tfvars is in .gitignore — never commit secrets.

gcp_project_id    = "your-project-id-here"
gcp_region        = "us-central1"
github_repository = "Hitsshaa/MicroservicesApp"
github_branch     = "main"

cloudsql_admin_username = "postgres"
cloudsql_admin_password = "ChangeMe_Strong_Password_1!"

# Optional cost levers
# cloudsql_tier        = "db-f1-micro"
# cloudsql_storage_gb  = 10
